<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LUXTIN-SENCI-GENERADOR</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Courier New', monospace; font-weight: bold; }
        html, body {
            min-height: 100vh;
            color: #fff;
            overflow-x: hidden;
            background-color: #000;
            background-attachment: fixed;
        }
        .oculto { display: none !important; }
        .centrar { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 15px; min-height: 100vh; position: relative; }

        #textoActualizado {
            position: absolute;
            top: 80px;
            left: 50%;
            transform: translateX(-50%);
            color: #ff0000;
            font-size: 2.5rem;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            letter-spacing: 2px;
            white-space: nowrap;
            text-shadow: 0 0 8px #ff0000;
            z-index: 10;
        }

        #fondoMatrix { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -2; }
        #codigosFlotantes { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; opacity: 0.3; font-size: 13px; color: #0f0; pointer-events: none; }

        #pantallaInicio {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0,0,0,0.55);
            z-index: 9999;
            display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px;
        }
        #pantallaPremium, #anuncioPeriodico {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0,0,0,0.92); z-index: 9999;
            display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px;
        }
        .panel-terminal {
            width: 100%; max-width: 480px;
            background: rgba(0,0,0,0.6);
            border: 3px solid #ff0000;
            padding: 20px 15px;
            position: relative;
            margin-top: 140px;
        }
        .linea-roja {
            height: 3px;
            background: repeating-linear-gradient(90deg, #ff0000, #ff0000 8px, transparent 8px, transparent 16px);
            margin: 12px 0;
        }
        .titulo-ascii {
            font-size: 4.5vw;
            line-height: 1;
            text-align: center;
            color: #fff;
            text-shadow: 0 0 8px #ff0000;
            margin: 10px 0;
            letter-spacing: 2px;
        }
        .subtitulo {
            text-align: center;
            color: #ff0000;
            font-size: 1.1rem;
            margin-bottom: 15px;
        }
        .opcion {
            font-size: 1.2rem;
            margin: 10px 0;
            color: #fff;
        }
        .opcion span { color: #ff0000; }

        .contenedor-botones {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin: 10px 0;
        }
        .boton-modo {
            width: auto;
            min-width: 90px;
            padding: 8px 12px;
            font-size: 1rem;
            margin: 0;
        }
        .boton-modo.activo {
            background: #ff3333;
            box-shadow: 0 0 12px #ff0000;
            transform: scale(1.05);
        }

        input, select, button {
            width: 100%; max-width: 380px; padding: 12px; margin: 8px auto; display:block;
            border: 2px solid #ff0000; border-radius: 0;
            font-size: 1.1rem; background: #111; color: #fff;
            font-family: inherit;
        }
        select:disabled { background: #0a0a0a; color: #555; border-color: #333; cursor: not-allowed; }
        select option { background: #000; color: #fff; }
        button { background: #ff0000; cursor: pointer; transition: 0.1s; }
        button:disabled { background: #440000; color: #777; border-color: #550000; cursor: not-allowed; }
        button:hover:not(:disabled):not(.boton-modo) { background: #ff3333; box-shadow: 0 0 10px #ff0000; }

        .resultado {
            background: rgba(5,5,5,0.8); padding: 15px; margin-top: 15px;
            border: 2px solid #ff0000;
            font-size: 1.1rem;
            line-height: 1.6;
        }
        .resultado strong { color: #0f0; }
        .aviso { color: #ff0000; text-align: center; margin: 8px 0; }

        .carga-siri {
            width: 60px; height: 60px; margin: 15px auto; position: relative;
        }
        .carga-siri::before, .carga-siri::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            border: 3px solid transparent; border-top-color: #fff; border-radius: 50%;
            animation: girar 1.2s linear infinite;
        }
        .carga-siri::after { border-top-color: #ff0000; animation-duration: 0.8s; animation-direction: reverse; }
        @keyframes girar { 100% { transform: rotate(360deg); } }

        #btnPremium { position: fixed; top: 10px; left: 10px; width: auto; padding: 5px 10px; font-size: 0.9rem; border: 1px solid #ff0000; z-index: 15; }
    </style>

    <script>
        const CLAVE_INGRESO = "50173533";
        const CORREO_PREMIUM = "50173533";
        const CLAVE_PREMIUM = "50173533";
        let esPremium = localStorage.getItem('esPremium') === 'SI';
        const TIEMPO_ANUNCIO = 2 * 60 * 60 * 1000;
        const TIEMPO_CIERRE_ANUNCIO = 3000;
        let modoSeleccionado = null;

        function animarActualizado() {
            const texto = "ACTUALIZADO - MODO HACKER";
            const elemento = document.getElementById('textoActualizado');
            let indice = 0;
            function escribir() {
                if (indice < texto.length) {
                    elemento.textContent = texto.substring(0, indice + 1);
                    indice++;
                    setTimeout(escribir, 120);
                } else {
                    elemento.textContent = texto + "...";
                    setTimeout(() => {
                        elemento.textContent = "";
                        indice = 0;
                        setTimeout(escribir, 500);
                    }, 1500);
                }
            }
            escribir();
        }

        const dispositivos = {
            "Samsung": ["A01","A02","A03","A04","A05","A10","A10s","A11","A12","A13","A14","A20","A20s","A21","A21s","A22","A23","A24","A30","A31","A32","A33","A34","A50","A51","A52","A53","A54","A70","A71","A72","A73","S8","S9","S10","S20","S21","S22","S23","S24","Note 9","Note 10","Note 20","M02","M11","M12","M20","M21","M30","M31","M51"],
            "Xiaomi": ["Redmi 8","Redmi 9","Redmi 10","Redmi 12","Redmi 13","Redmi Note 7","Note 8","Note 9","Note 10","Note 11","Note 12","Note 13","Poco M3","Poco M4","Poco M5","Poco X3","Poco X4","Poco X5","Mi 9","Mi 10","Mi 11","Mi 12","Mi 13","11 Lite","12 Lite","13 Lite"],
            "Motorola": ["E6","E7","E20","E22","E32","G7","G8","G9","G10","G20","G22","G30","G40","G50","G52","G60","G82","G84","Edge 20","Edge 30","Edge 40","Moto G54","Moto G84"],
            "Huawei": ["Y5","Y6","Y7","Y8","Y9","P20","P30","P40","P50","P60","Mate 20","Mate 30","Mate 40","Nova 5","Nova 7","Nova 8","Nova 9","Nova 10","Honor 8X","Honor 10 Lite","Honor X7","Honor X8"],
            "Oppo": ["A3s","A5","A9","A11","A12","A15","A16","A31","A32","A53","A54","A74","Reno 4","Reno 5","Reno 6","Reno 7","Reno 8","Reno 9","Find X3","Find X5"],
            "Vivo": ["Y11","Y12","Y15","Y17","Y20","Y21","Y22","Y30","Y31","Y50","Y51","Y72","V19","V20","V21","V23","V25","X60","X70","X80"],
            "Realme": ["C2","C3","C11","C12","C15","C21","C25","C30","C31","C35","C53","Narzo 10","Narzo 20","Narzo 30","Narzo 50","GT Neo 2","GT Neo 3","GT Master"],
            "Infinix": ["Hot 9","Hot 10","Hot 11","Hot 12","Hot 20","Note 7","Note 8","Note 10","Note 11","Note 12","Note 30","Note 40","Note 40 Pro","Zero 8","Zero X","Zero 30","Smart 5","Smart 6","Smart 7"],
            "Tecno": ["Spark 5","Spark 6","Spark 7","Spark 8","Pouvoir 3","Pouvoir 4","Pouvoir 5","Camon 17","Camon 18","Camon 19","Camon 20","Phantom X"],
            "Itel": ["A23","A33","Vision 1","Vision 2","Vision 3","Power 40","Power 55"],
            "LG": ["K22","K42","K52","K61","Q60","Q70","Velvet","Wing"],
            "Sony": ["Xperia L1","L3","L4","10","10 II","10 III","5","5 II","5 III","1","1 II","1 III"],
            "Asus": ["Zenfone Max","Zenfone 8","Zenfone 9","Zenfone 10","ROG Phone 3","ROG Phone 5","ROG Phone 6"],
            "Lenovo": ["Vibe K5","Moto Tab","Legion Duel","Legion Y70"],
            "Google": ["Pixel 3","4","4a","5","5a","6","6a","7","7a","8","8 Pro"],
            "Nubia": ["Red Magic 5G","6","6 Pro","7","7 Pro","Z50"],
            "ZTE": ["Blade A5","A7","V20","Axon 20","Axon 30"],
            "iPhone": ["iPhone 6","6 Plus","6s","6s Plus","SE 1ª Gen","7","7 Plus","8","8 Plus","X","XR","XS","XS Max","11","11 Pro","11 Pro Max","SE 2ª Gen","12 Mini","12","12 Pro","12 Pro Max","13 Mini","13","13 Pro","13 Pro Max","SE 3ª Gen","14","14 Plus","14 Pro","14 Pro Max","15","15 Plus","15 Pro","15 Pro Max"]
        };

        function calcularSensi(marca, modelo, modo) {
            const porMarca = {
                "Samsung": { factor: 1.07 }, "Xiaomi": { factor: 1.10 }, "Motorola": { factor: 1.05 },
                "Huawei": { factor: 1.06 }, "Oppo": { factor: 1.08 }, "Vivo": { factor: 1.08 },
                "Realme": { factor: 1.09 }, "Infinix": { factor: 1.12 }, "Tecno": { factor: 1.11 },
                "Itel": { factor: 1.13 }, "LG": { factor: 1.04 }, "Sony": { factor: 1.03 },
                "Asus": { factor: 1.02 }, "Lenovo": { factor: 1.04 }, "Google": { factor: 1.02 },
                "Nubia": { factor: 1.02 }, "ZTE": { factor: 1.11 }, "iPhone": { factor: 0.97 }
            };

            const modos = {
                "pvp": {
                    nombre: "PVP - SALAS Y COMBATE",
                    descripcion: "Más rápida, levanta mira fácil y pega rojo en enfrentamientos",
                    general: 192, puntoRojo: 190, mira2x: 185, mira4x: 178, francotirador: 162, camara360: 195, boton: 42
                },
                "br": {
                    nombre: "BR - MAPAS GRANDES",
                    descripcion: "Rápida y precisa, llega a la cabeza desde cualquier distancia",
                    general: 182, puntoRojo: 178, mira2x: 172, mira4x: 168, francotirador: 172, camara360: 185, boton: 41
                },
                "de": {
                    nombre: "DE - MAPAS MEDIANOS",
                    descripcion: "Máxima respuesta, mira se pega a la cabeza al moverte",
                    general: 188, puntoRojo: 185, mira2x: 180, mira4x: 174, francotirador: 160, camara360: 190, boton: 42
                },
                "1vs6": {
                    nombre: "🔥 1 VS 6 - MODO HACKER",
                    descripcion: "SENSIBILIDAD POTENTE: al levantar la mira VA DIRECTO A LA CABEZA, mata uno por uno sin esfuerzo",
                    general: 200, puntoRojo: 199, mira2x: 195, mira4x: 190, francotirador: 172, camara360: 200, boton: 44
                },
                "ump": {
                    nombre: "💥 UMP Y ESCOPETA M1887 - TODO ROJO",
                    descripcion: "SUBIDA INSTANTÁNEA: cada disparo se clava en la cabeza, no fallas ni un tiro",
                    general: 200, puntoRojo: 200, mira2x: 192, mira4x: 185, francotirador: 150, camara360: 200, boton: 45
                }
            };

            const ajuste = modos[modo];
            const factor = porMarca[marca]?.factor || 1;
            
            return {
                ...ajuste,
                general: Math.min(200, Math.max(1, Math.round(ajuste.general * factor))),
                puntoRojo: Math.min(200, Math.max(1, Math.round(ajuste.puntoRojo * factor))),
                mira2x: Math.min(200, Math.max(1, Math.round(ajuste.mira2x * factor))),
                mira4x: Math.min(200, Math.max(1, Math.round(ajuste.mira4x * factor))),
                francotirador: Math.min(200, Math.max(1, Math.round(ajuste.francotirador * factor))),
                camara360: Math.min(200, Math.max(1, Math.round(ajuste.camara360 * factor)))
            };
        }

        function iniciarAnuncios() {
            setInterval(() => {
                if(!esPremium) {
                    document.getElementById('anuncioPeriodico').classList.remove('oculto');
                    setTimeout(() => {
                        document.getElementById('anuncioPeriodico').classList.add('oculto');
                    }, TIEMPO_CIERRE_ANUNCIO);
                }
            }, TIEMPO_ANUNCIO);
        }

        window.addEventListener('DOMContentLoaded', () => {
            const selMarca = document.getElementById('marca');
            Object.keys(dispositivos).forEach(m => {
                let opt = document.createElement('option'); opt.value = m; opt.textContent = m; selMarca.appendChild(opt);
            });
            const selMod = document.getElementById('modelo');
            const btnGen = document.getElementById('btnGenerar');
            const botonesModo = document.querySelectorAll('.boton-modo');

            botonesModo.forEach(boton => {
                boton.addEventListener('click', () => {
                    botonesModo.forEach(b => b.classList.remove('activo'));
                    boton.classList.add('activo');
                    modoSeleccionado = boton.dataset.modo;
                    btnGen.disabled = !(selMarca.value && selMod.value && modoSeleccionado);
                });
            });

            selMarca.addEventListener('change', () => {
                selMod.innerHTML = '<option value="">-- Primero elegí marca --</option>';
                selMod.disabled = true;
                modoSeleccionado = null;
                botonesModo.forEach(b => b.classList.remove('activo'));
                btnGen.disabled = true;
                document.getElementById('resultado').classList.add('oculto');
                const marcaElegida = selMarca.value;
                if(marcaElegida) {
                    dispositivos[marcaElegida].forEach(mod => {
                        let opt = document.createElement('option'); opt.value = mod; opt.textContent = mod; selMod.appendChild(opt);
                    });
                    selMod.disabled = false;
                }
            });

            selMod.addEventListener('change', () => {
                btnGen.disabled = !(selMarca.value && selMod.value && modoSeleccionado);
                document.getElementById('resultado').classList.add('oculto');
            });

            if(esPremium) document.getElementById('btnPremium').textContent = "✅ PREMIUM";
            animarCodigos();
        });

        function verificarClaveIngreso() {
            const c = document.getElementById('claveIngreso').value.trim().toUpperCase();
            if(c === CLAVE_INGRESO) {
                document.getElementById('pantallaInicio').classList.add('oculto');
                document.getElementById('contenidoTotal').classList.remove('oculto');
                animarActualizado();
                if(!esPremium) iniciarAnuncios();
            } else {
                document.getElementById('mensajeClave').textContent = "❌ CLAVE INCORRECTA - USÁ: MINI TALENTO 777";
            }
        }

        function activarPremium() {
            const co = document.getElementById('correoPremium').value.trim().toLowerCase();
            const cl = document.getElementById('clavePremiumIngreso').value.trim();
            if(co === CORREO_PREMIUM && cl === CLAVE_PREMIUM) {
                esPremium = true; localStorage.setItem('esPremium', 'SI');
                document.getElementById('pantallaPremium').classList.add('oculto');
                document.getElementById('btnPremium').textContent = "✅ PREMIUM";
            } else document.getElementById('mensajePremium').textContent = "❌ ACCESO DENEGADO";
        }

        function generarSensibilidad() {
            document.getElementById('cargaGeneracion').classList.remove('oculto');
            document.getElementById('resultado').classList.add('oculto');
            setTimeout(() => {
                const sensi = calcularSensi(
                    document.getElementById('marca').value,
                    document.getElementById('modelo').value,
                    modoSeleccionado
                );
                document.getElementById('tituloResultado').textContent = sensi.nombre;
                document.getElementById('descripcionResultado').textContent = sensi.descripcion;
                document.getElementById('valGeneral').textContent = sensi.general;
                document.getElementById('valPuntoRojo').textContent = sensi.puntoRojo;
                document.getElementById('val2x').textContent = sensi.mira2x;
                document.getElementById('val4x').textContent = sensi.mira4x;
                document.getElementById('valSniper').textContent = sensi.francotirador;
                document.getElementById('valCamara').textContent = sensi.camara360;
                document.getElementById('valBoton').textContent = sensi.boton;

                document.getElementById('cargaGeneracion').classList.add('oculto');
                document.getElementById('resultado').classList.remove('oculto');
            }, 1500);
        }

        function animarCodigos() {
            const cont = document.getElementById('codigosFlotantes');
            const codigos = ['01001011','aimbot_head()','mov eax, 200','// MODO HACKER ACTIVO','todo_rojo = true;'];
            setInterval(() => {
                const div = document.createElement('div');
                div.textContent = codigos[Math.floor(Math.random()*codigos.length)];
                div.style.position = 'absolute'; div.style.left = Math.random()*100+'%'; div.style.top = '-20px';
                cont.appendChild(div);
                let alt = -20;
                const bajar = setInterval(() => {
                    alt += 1.5; div.style.top = alt+'px';
                    if(alt > window.innerHeight) { clearInterval(bajar); cont.removeChild(div); }
                }, 50);
            }, 400);
        }
    </script>
</head>
<body>

    <canvas id="fondoMatrix"></canvas>
    <script>
        const canvas = document.getElementById('fondoMatrix');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const letras = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        const tam = 16; const cols = canvas.width/tam; const lluvia = [];
        for(let i=0; i<cols; i++) lluvia[i] = 1;
        function dibujar(){
            ctx.fillStyle='rgba(0,0,0,0.05)'; ctx.fillRect(0,0,canvas.width,canvas.height);
            ctx.fillStyle='#0f0'; ctx.font = tam+'px monospace';
            for(let i=0; i<lluvia.length; i++){
                const txt = letras[Math.floor(Math.random()*letras.length)];
                ctx.fillText(txt, i*tam, lluvia[i]*tam);
                if(lluvia[i]*tam>canvas.height && Math.random()>0.975) lluvia[i]=0;
                lluvia[i]++;
            }
        }
        setInterval(dibujar, 50);
    </script>
    <div id="codigosFlotantes"></div>

    <div id="pantallaInicio">
