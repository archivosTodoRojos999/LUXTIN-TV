                    <div class="linea-roja"></div>
                </div>
            </div>
        </div>
    </div>

    <div id="pantallaPremium" class="oculto">
        <div class="panel-terminal">
            <h2>ACTIVAR MODO PREMIUM</h2>
            <input type="email" id="correoPremium" placeholder="Tu correo autorizado">
            <input type="password" id="clavePremiumIngreso" placeholder="Clave Premium">
            <button onclick="activarPremium()">✅ ACTIVAR SIN ANUNCIOS</button>
            <button onclick="document.getElementById('pantallaPremium').classList.add('oculto')" style="background:#333;">❌ VOLVER</button>
            <div id="mensajePremium" class="aviso"></div>
        </div>
    </div>

    <div id="anuncioPeriodico" class="oculto">
        <div class="panel-terminal">
            <div class="titulo-ascii">MINI TALENTO 777</div>
